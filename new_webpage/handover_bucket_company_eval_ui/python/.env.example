# Server-side only. Do NOT expose in browser.
OPENAI_API_KEY=

# Model selection
OPENAI_MODEL=gpt-4.1-mini

# Cost guardrails (recommended)
MANUAV_MAX_TOOL_CALLS=2
MANUAV_SECOND_QUERY_ON_UNCERTAINTY=1

# Optional: gated retry (extra cost, only triggers on low confidence)
MANUAV_RETRY_DISAMBIGUATION_ON_LOW_CONFIDENCE=0
MANUAV_RETRY_MAX_TOOL_CALLS=3

# Optional: Flex (slower, cheaper tokens; web-search billing separate)
MANUAV_SERVICE_TIER=auto
MANUAV_OPENAI_TIMEOUT_SECONDS=60
MANUAV_FLEX_MAX_RETRIES=5
MANUAV_FLEX_FALLBACK_TO_AUTO=1
MANUAV_FLEX_TOKEN_DISCOUNT=0.5

# Optional: prompt caching (model-dependent)
MANUAV_PROMPT_CACHE=0
MANUAV_PROMPT_CACHE_RETENTION=24h

# Optional: rubric override (otherwise service uses its bundled rubric)
# MANUAV_RUBRIC_FILE=./rubrics/manuav_rubric_v4_en.md

# Optional: CORS (only needed if your UI calls this service directly from a different origin)
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

