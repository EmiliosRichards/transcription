# --- Required ---
GEMINI_API_KEY="YOUR_KEY_HERE"

# --- Golden partners ---
# Point this at your golden partner Excel/CSV
PATH_TO_GOLDEN_PARTNERS_DATA="data/kgs_001_ER47_20250626.xlsx"

# --- Prompts (only override if you moved/copied prompts elsewhere) ---
PROMPT_PATH_ATTRIBUTE_EXTRACTOR="prompts/attribute_extractor_prompt.txt"
PROMPT_PATH_GERMAN_PARTNER_MATCHING="prompts/german_partner_matching_prompt.txt"
PROMPT_PATH_GERMAN_SALES_PITCH_GENERATION="prompts/german_sales_pitch_generation_prompt.txt"

# --- UI description-driven mode: short German summary (≤100 words) ---
PROMPT_PATH_GERMAN_SHORT_SUMMARY_FROM_DESCRIPTION="prompts/german_short_summary_from_description_prompt.txt"
LLM_MAX_INPUT_CHARS_FOR_DESCRIPTION_DE_SUMMARY="12000"
LLM_MAX_TOKENS_DESCRIPTION_DE_SUMMARY="256"

# --- Optional: phone extraction toggle defaults ---
ENABLE_PHONE_LLM_RERANK="True"
PHONE_LLM_RERANK_MAX_CANDIDATES="25"
PHONE_LLM_MAX_CANDIDATES_TOTAL="120"
TARGET_COUNTRY_CODES="DE,AT,CH"
DEFAULT_REGION_CODE="DE"

# --- Logging (recommended for a web backend) ---
LOG_LEVEL="INFO"
CONSOLE_LOG_LEVEL="INFO"

