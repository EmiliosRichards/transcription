## Dexter v2 Fixed Taxonomy - environment variables
## Copy this file to: .env (repo root) or dexter_v2_fixed_taxonomy/.env and fill values.
## Do NOT commit your real .env file.

# Postgres connection string (psycopg2 / SQLAlchemy)
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Dialfire reporting DB (for success/declined/open filtering; optional for now, required for "skip successes" logic)
# Example if you create an SSH tunnel: ssh -L 5434:localhost:5432 root@185.216.75.247
# Then set host=localhost port=5434 here.
DIALFIRE_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5434/dbname

# OpenAI API key (required for real classification runs)
OPENAI_API_KEY=sk-...

# Optional: model override (defaults to gpt-4o-mini)
DEXTER_V2_MODEL=gpt-4o-mini

